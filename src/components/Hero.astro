---
import heroMockup from '../assets/images/hero-mockup.png';
---

<section id="hero" class="hero">
  <!-- Decorative background elements -->
  <div class="hero__bg">
    <div class="hero__orb hero__orb--1"></div>
    <div class="hero__orb hero__orb--2"></div>
    <div class="hero__orb hero__orb--3"></div>
    <div class="hero__dots"></div>
    <div class="hero__grid-pattern"></div>
  </div>

  <div class="container hero__container">
    <!-- Left content column -->
    <div class="hero__content animate-slide-left">
      <span class="hero__badge animate-fade-in-up">
        <span class="hero__badge-emoji">🍳</span>
        <span>Smart Kitchen Assistant</span>
      </span>

      <h1 class="hero__title animate-fade-in-up animate-delay-1">
        Your Kitchen, <span class="hero__title-accent">Smarter</span> and Simpler
      </h1>

      <p class="hero__subtitle animate-fade-in-up animate-delay-2">
        Snap a photo of your pantry ingredients and instantly discover custom recipes.
        Turn what you have into delicious meals without the waste.
      </p>

      <div class="hero__actions animate-fade-in-up animate-delay-3">
        <a href="#download" class="btn btn--primary btn--lg hero__cta-primary">
          <svg class="hero__cta-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download Now
        </a>
        <a href="#features" class="btn btn--secondary btn--lg hero__cta-secondary">
          Learn More
          <svg class="hero__cta-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <!-- Social proof row -->
      <div class="hero__proof animate-fade-in-up animate-delay-4">
        <div class="hero__proof-avatars">
          <div class="hero__proof-avatar" style="background: #FF385C;">🧑‍🍳</div>
          <div class="hero__proof-avatar" style="background: #FF6B6B;">👩‍🍳</div>
          <div class="hero__proof-avatar" style="background: #FFA07A;">👨‍🍳</div>
        </div>
        <div class="hero__proof-text">
          <span class="hero__proof-number">10k+</span> home cooks already cooking smarter
        </div>
      </div>
    </div>

    <!-- Right mockup column -->
    <div class="hero__visual animate-slide-right animate-delay-2">
      <div class="hero__mockup-wrapper">
        <!-- Glow effect behind the phone -->
        <div class="hero__mockup-glow"></div>
        <!-- Floating accent cards -->
        <div class="hero__floating-card hero__floating-card--top">
          <span class="hero__card-icon">📸</span>
          <span class="hero__card-text">Snap ingredients</span>
        </div>
        <div class="hero__floating-card hero__floating-card--bottom">
          <span class="hero__card-icon">✨</span>
          <span class="hero__card-text">Smart recipes ready!</span>
        </div>
        <!-- Phone mockup -->
        <img
          src={heroMockup.src}
          alt="Laook app mockup showing smart recipe recommendation interface"
          class="hero__mockup-img animate-float"
          width={heroMockup.width}
          height={heroMockup.height}
          loading="eager"
        />
      </div>
    </div>
  </div>

  <!-- Curved bottom divider -->
  <div class="hero__divider">
    <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0 60L60 52C120 44 240 28 360 22C480 16 600 20 720 26C840 32 960 40 1080 42C1200 44 1320 40 1380 38L1440 36V60H1380C1320 60 1200 60 1080 60C960 60 840 60 720 60C600 60 480 60 360 60C240 60 120 60 60 60H0Z" fill="var(--color-surface)"/>
    </svg>
  </div>
</section>

<style>
  /* ==========================================
     Hero Section — Premium Landing Block
     ========================================== */

  .hero {
    position: relative;
    overflow: hidden;
    padding-top: 72px; /* Fixed navbar offset */
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: linear-gradient(
      160deg,
      #0f0f1a 0%,
      #1a1a2e 25%,
      #16213e 50%,
      #1a1a2e 75%,
      #0f0f1a 100%
    );
  }

  /* ---- Decorative Background ---- */

  .hero__bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  /* Gradient orbs */
  .hero__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    animation: pulse 6s ease-in-out infinite;
  }

  .hero__orb--1 {
    width: 500px;
    height: 500px;
    background: var(--color-primary);
    top: -10%;
    left: -8%;
    animation-delay: 0s;
  }

  .hero__orb--2 {
    width: 400px;
    height: 400px;
    background: var(--color-primary-light);
    bottom: -5%;
    right: -5%;
    animation-delay: 2s;
  }

  .hero__orb--3 {
    width: 250px;
    height: 250px;
    background: #FFA07A;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    animation-delay: 4s;
    opacity: 0.2;
  }

  /* Dot grid pattern */
  .hero__dots {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px);
    background-size: 32px 32px;
  }

  /* Subtle grid lines */
  .hero__grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    background-size: 80px 80px;
  }

  /* ---- Main Layout ---- */

  .hero__container {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: var(--space-3xl);
    padding-top: var(--space-4xl);
    padding-bottom: var(--space-5xl);
  }

  /* ---- Left: Content ---- */

  .hero__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  /* Badge */
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    width: fit-content;
    padding: var(--space-sm) var(--space-md);
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-primary-light);
    background: rgba(255, 56, 92, 0.12);
    border: 1px solid rgba(255, 56, 92, 0.2);
    border-radius: var(--radius-pill);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hero__badge-emoji {
    font-size: 1rem;
    line-height: 1;
  }

  /* Title */
  .hero__title {
    font-family: var(--font-display);
    font-size: var(--fs-display);
    font-weight: 800;
    line-height: var(--lh-tight);
    color: #FFFFFF;
    letter-spacing: -0.02em;
  }

  .hero__title-accent {
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Subtitle */
  .hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--fs-body-lg);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.65);
    max-width: 480px;
  }

  /* CTA Buttons */
  .hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    padding-top: var(--space-sm);
  }

  .hero__cta-primary {
    position: relative;
    overflow: hidden;
  }

  .hero__cta-primary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.2) 0%,
      transparent 50%
    );
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .hero__cta-primary:hover::before {
    opacity: 1;
  }

  .hero__cta-secondary {
    background: rgba(255, 255, 255, 0.06);
    color: rgba(255, 255, 255, 0.9);
    border-color: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .hero__cta-secondary:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.3);
    color: #FFFFFF;
  }

  .hero__cta-icon {
    flex-shrink: 0;
  }

  /* Social Proof */
  .hero__proof {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-top: var(--space-lg);
    margin-top: var(--space-sm);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .hero__proof-avatars {
    display: flex;
  }

  .hero__proof-avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    border: 2px solid #1a1a2e;
    margin-left: -8px;
  }

  .hero__proof-avatar:first-child {
    margin-left: 0;
  }

  .hero__proof-text {
    font-size: var(--fs-caption);
    color: rgba(255, 255, 255, 0.5);
    line-height: var(--lh-normal);
  }

  .hero__proof-number {
    font-weight: 700;
    color: var(--color-primary-light);
  }

  /* ---- Right: Visual / Mockup ---- */

  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
  }

  .hero__mockup-wrapper {
    position: relative;
    max-width: 380px;
    width: 100%;
  }

  /* Glow behind phone */
  .hero__mockup-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 110%;
    height: 110%;
    background: radial-gradient(
      ellipse at center,
      rgba(255, 56, 92, 0.25) 0%,
      rgba(255, 107, 107, 0.1) 40%,
      transparent 70%
    );
    border-radius: 50%;
    filter: blur(40px);
    z-index: 0;
    animation: pulse 5s ease-in-out infinite;
  }

  /* Phone image */
  .hero__mockup-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    border-radius: var(--radius-xl);
    filter: drop-shadow(0 20px 60px rgba(255, 56, 92, 0.25))
            drop-shadow(0 8px 20px rgba(0, 0, 0, 0.4));
  }

  /* Floating accent cards */
  .hero__floating-card {
    position: absolute;
    z-index: 2;
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm) var(--space-md);
    background: rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-lg);
    color: #FFFFFF;
    font-size: var(--fs-caption);
    font-weight: 600;
    white-space: nowrap;
    animation: float 5s ease-in-out infinite;
  }

  .hero__floating-card--top {
    top: 12%;
    left: -20%;
    animation-delay: 0.5s;
  }

  .hero__floating-card--bottom {
    bottom: 18%;
    right: -18%;
    animation-delay: 2s;
  }

  .hero__card-icon {
    font-size: 1.2rem;
    line-height: 1;
  }

  .hero__card-text {
    font-family: var(--font-body);
  }

  /* ---- Bottom Divider ---- */

  .hero__divider {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    z-index: 1;
    line-height: 0;
  }

  .hero__divider svg {
    width: 100%;
    height: 60px;
  }

  /* ==========================================
     Responsive — Tablet
     ========================================== */

  @media (max-width: 1024px) {
    .hero__container {
      gap: var(--space-2xl);
    }

    .hero__mockup-wrapper {
      max-width: 320px;
    }

    .hero__floating-card--top {
      left: -10%;
    }

    .hero__floating-card--bottom {
      right: -10%;
    }
  }

  /* ==========================================
     Responsive — Mobile
     ========================================== */

  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding-top: 72px;
    }

    .hero__container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: var(--space-2xl);
      padding-top: var(--space-3xl);
      padding-bottom: calc(var(--space-4xl) + 30px);
    }

    .hero__content {
      align-items: center;
    }

    .hero__subtitle {
      max-width: 100%;
    }

    .hero__actions {
      justify-content: center;
    }

    .hero__proof {
      justify-content: center;
      flex-direction: column;
      gap: var(--space-sm);
    }

    .hero__visual {
      order: -1; /* Show mockup on top on mobile */
    }

    .hero__mockup-wrapper {
      max-width: 260px;
    }

    .hero__floating-card--top {
      top: 5%;
      left: -5%;
      font-size: var(--fs-small);
      padding: var(--space-xs) var(--space-sm);
    }

    .hero__floating-card--bottom {
      bottom: 12%;
      right: -5%;
      font-size: var(--fs-small);
      padding: var(--space-xs) var(--space-sm);
    }

    .hero__orb--1 {
      width: 280px;
      height: 280px;
    }

    .hero__orb--2 {
      width: 220px;
      height: 220px;
    }

    .hero__orb--3 {
      width: 150px;
      height: 150px;
    }
  }

  /* ==========================================
     Reduced Motion
     ========================================== */

  @media (prefers-reduced-motion: reduce) {
    .hero__orb,
    .hero__mockup-glow {
      animation: none;
    }

    .hero__floating-card {
      animation: none;
    }
  }
</style>
