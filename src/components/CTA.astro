---
---

<section id="cta" class="cta section">
  <!-- Decorative background elements -->
  <div class="cta__bg-orbs" aria-hidden="true">
    <div class="cta__orb cta__orb--1"></div>
    <div class="cta__orb cta__orb--2"></div>
    <div class="cta__orb cta__orb--3"></div>
  </div>

  <!-- Dot pattern overlay -->
  <div class="cta__pattern" aria-hidden="true"></div>

  <!-- Floating food emojis -->
  <div class="cta__floaters" aria-hidden="true">
    <span class="cta__emoji cta__emoji--1">🍳</span>
    <span class="cta__emoji cta__emoji--2">🥗</span>
    <span class="cta__emoji cta__emoji--3">🍕</span>
    <span class="cta__emoji cta__emoji--4">🥘</span>
    <span class="cta__emoji cta__emoji--5">🍜</span>
    <span class="cta__emoji cta__emoji--6">🌶️</span>
    <span class="cta__emoji cta__emoji--7">🍰</span>
    <span class="cta__emoji cta__emoji--8">🫕</span>
  </div>

  <div class="cta__content container">
    <!-- Badge -->
    <div class="cta__badge animate-fade-in-up">
      <span class="cta__badge-dot"></span>
      Get Started Today
    </div>

    <!-- Headline -->
    <h2 class="cta__headline animate-fade-in-up animate-delay-1">
      Ready to Transform<br />
      <span class="cta__headline-accent">Your Cooking?</span>
    </h2>

    <!-- Subtext -->
    <p class="cta__subtext animate-fade-in-up animate-delay-2">
      Join thousands of home cooks who are already using AI to discover
      amazing recipes from their ingredients.
    </p>

    <!-- Email signup -->
    <form class="cta__form animate-fade-in-up animate-delay-3" onsubmit="return false;">
      <div class="cta__input-group">
        <svg class="cta__input-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="4" width="20" height="16" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        <input
          type="email"
          class="cta__input"
          placeholder="Enter your email for updates"
          aria-label="Email for updates"
          required
        />
        <button type="submit" class="cta__subscribe-btn">
          Subscribe
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </button>
      </div>
      <p class="cta__form-note">🔒 No spam, ever. Unsubscribe anytime.</p>
    </form>

    <!-- Action buttons -->
    <div class="cta__buttons animate-fade-in-up animate-delay-4">
      <a href="#" class="cta__btn-primary">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.523 2.236a.5.5 0 0 0-.843-.24L13.1 5.577l-2.82-.565a.5.5 0 0 0-.47.163L3.1 12.883a.5.5 0 0 0 .141.72l2.82 1.882-1.41 1.412a.5.5 0 0 0 0 .706l2.747 2.747a.5.5 0 0 0 .706 0L9.515 18.94l1.882 2.818a.5.5 0 0 0 .72.142l7.708-6.71a.5.5 0 0 0 .163-.47l-.565-2.82 3.581-3.58a.5.5 0 0 0-.24-.843l-5.241-1.241-1.241-5.241Z"/>
        </svg>
        Download for Android
      </a>
      <a href="https://github.com/LaookProj" target="_blank" rel="noopener" class="cta__btn-outline">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Social proof -->
    <div class="cta__proof animate-fade-in-up animate-delay-5">
      <div class="cta__avatars">
        <span class="cta__avatar">👨‍🍳</span>
        <span class="cta__avatar">👩‍🍳</span>
        <span class="cta__avatar">🧑‍🍳</span>
        <span class="cta__avatar">👨‍🍳</span>
      </div>
      <p class="cta__proof-text">
        <strong>2,000+</strong> cooks already building with Laook
      </p>
    </div>
  </div>
</section>

<style>
  .cta {
    position: relative;
    background: linear-gradient(160deg, #0f0f1a 0%, #1a1a2e 30%, #16213e 60%, #0f0f1a 100%);
    overflow: hidden;
    padding: var(--space-5xl) 0;
  }

  /* --- Background Orbs --- */
  .cta__bg-orbs {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .cta__orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
  }

  .cta__orb--1 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--color-primary) 0%, transparent 70%);
    top: -150px;
    right: -100px;
    animation: orbPulse 6s ease-in-out infinite;
  }

  .cta__orb--2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, #6366f1 0%, transparent 70%);
    bottom: -120px;
    left: -80px;
    animation: orbPulse 8s ease-in-out infinite 2s;
  }

  .cta__orb--3 {
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, #f59e0b 0%, transparent 70%);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    opacity: 0.15;
    animation: orbPulse 7s ease-in-out infinite 1s;
  }

  @keyframes orbPulse {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.2); opacity: 0.45; }
  }

  /* --- Dot Pattern --- */
  .cta__pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 32px 32px;
    z-index: 0;
    pointer-events: none;
  }

  /* --- Floating Emojis --- */
  .cta__floaters {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .cta__emoji {
    position: absolute;
    font-size: 2rem;
    opacity: 0.12;
    animation: emojiFloat 8s ease-in-out infinite;
  }

  .cta__emoji--1 { top: 8%; left: 5%; animation-delay: 0s; animation-duration: 7s; }
  .cta__emoji--2 { top: 15%; right: 8%; animation-delay: 1s; animation-duration: 9s; }
  .cta__emoji--3 { top: 40%; left: 3%; animation-delay: 2s; animation-duration: 6s; }
  .cta__emoji--4 { top: 60%; right: 4%; animation-delay: 0.5s; animation-duration: 8s; }
  .cta__emoji--5 { bottom: 20%; left: 8%; animation-delay: 3s; animation-duration: 7.5s; }
  .cta__emoji--6 { bottom: 10%; right: 12%; animation-delay: 1.5s; animation-duration: 6.5s; }
  .cta__emoji--7 { top: 25%; left: 15%; animation-delay: 2.5s; animation-duration: 9.5s; }
  .cta__emoji--8 { bottom: 30%; right: 18%; animation-delay: 0.8s; animation-duration: 8.5s; }

  @keyframes emojiFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    25% { transform: translateY(-18px) rotate(5deg); }
    50% { transform: translateY(-8px) rotate(-3deg); }
    75% { transform: translateY(-22px) rotate(4deg); }
  }

  /* --- Content --- */
  .cta__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* --- Badge --- */
  .cta__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-xs) var(--space-md);
    background: rgba(255, 56, 92, 0.12);
    border: 1px solid rgba(255, 56, 92, 0.25);
    border-radius: var(--radius-pill);
    font-size: var(--fs-small);
    font-weight: 600;
    color: var(--color-primary-light);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: var(--space-xl);
  }

  .cta__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
    animation: pulse 2s ease-in-out infinite;
  }

  /* --- Headline --- */
  .cta__headline {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.5vw, 3.75rem);
    font-weight: 800;
    line-height: var(--lh-tight);
    color: #ffffff;
    margin-bottom: var(--space-lg);
    max-width: 700px;
  }

  .cta__headline-accent {
    background: var(--gradient-hero);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* --- Subtext --- */
  .cta__subtext {
    font-size: var(--fs-body-lg);
    line-height: var(--lh-relaxed);
    color: rgba(255, 255, 255, 0.65);
    max-width: 560px;
    margin-bottom: var(--space-2xl);
  }

  /* --- Email Form --- */
  .cta__form {
    width: 100%;
    max-width: 520px;
    margin-bottom: var(--space-2xl);
  }

  .cta__input-group {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius-pill);
    padding: 5px 5px 5px var(--space-md);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .cta__input-group:focus-within {
    border-color: var(--color-primary);
    background: rgba(255, 255, 255, 0.1);
    box-shadow: 0 0 0 3px rgba(255, 56, 92, 0.15), var(--shadow-glow);
  }

  .cta__input-icon {
    color: rgba(255, 255, 255, 0.35);
    flex-shrink: 0;
    margin-right: var(--space-sm);
  }

  .cta__input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: var(--fs-body);
    padding: var(--space-sm) 0;
    min-width: 0;
  }

  .cta__input::placeholder {
    color: rgba(255, 255, 255, 0.35);
  }

  .cta__subscribe-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: var(--space-sm) var(--space-lg);
    background: var(--gradient-cta);
    color: #ffffff;
    font-family: var(--font-body);
    font-size: var(--fs-caption);
    font-weight: 600;
    border: none;
    border-radius: var(--radius-pill);
    cursor: pointer;
    white-space: nowrap;
    transition: all var(--duration-normal) var(--ease-out);
    flex-shrink: 0;
  }

  .cta__subscribe-btn:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-lg), var(--shadow-glow);
  }

  .cta__subscribe-btn:active {
    transform: translateY(0);
  }

  .cta__form-note {
    font-size: var(--fs-small);
    color: rgba(255, 255, 255, 0.35);
    margin-top: var(--space-sm);
  }

  /* --- Buttons --- */
  .cta__buttons {
    display: flex;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
    flex-wrap: wrap;
    justify-content: center;
  }

  .cta__btn-primary {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-2xl);
    background: var(--gradient-cta);
    color: #ffffff;
    font-family: var(--font-body);
    font-size: var(--fs-body-lg);
    font-weight: 600;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-md), 0 0 40px rgba(255, 56, 92, 0.25);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .cta__btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-xl), 0 0 60px rgba(255, 56, 92, 0.4);
  }

  .cta__btn-primary:active {
    transform: translateY(-1px);
  }

  .cta__btn-outline {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-2xl);
    background: transparent;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: var(--fs-body-lg);
    font-weight: 600;
    border: 2px solid rgba(255, 255, 255, 0.3);
    border-radius: var(--radius-pill);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .cta__btn-outline:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.06);
    box-shadow: 0 0 30px rgba(255, 255, 255, 0.08);
  }

  .cta__btn-outline:active {
    transform: translateY(-1px);
  }

  /* --- Social Proof --- */
  .cta__proof {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .cta__avatars {
    display: flex;
  }

  .cta__avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.1);
    border: 2px solid rgba(255, 255, 255, 0.15);
    font-size: 1rem;
    margin-left: -8px;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .cta__avatar:first-child {
    margin-left: 0;
  }

  .cta__avatar:hover {
    transform: translateY(-3px);
    z-index: 1;
  }

  .cta__proof-text {
    font-size: var(--fs-caption);
    color: rgba(255, 255, 255, 0.5);
  }

  .cta__proof-text strong {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 700;
  }

  /* --- Responsive --- */
  @media (max-width: 768px) {
    .cta {
      padding: var(--space-3xl) 0;
    }

    .cta__emoji {
      font-size: 1.4rem;
      opacity: 0.08;
    }

    .cta__input-group {
      flex-direction: column;
      border-radius: var(--radius-lg);
      padding: var(--space-sm);
      gap: var(--space-sm);
    }

    .cta__input-icon {
      display: none;
    }

    .cta__input {
      width: 100%;
      text-align: center;
      padding: var(--space-sm);
    }

    .cta__subscribe-btn {
      width: 100%;
      justify-content: center;
      padding: var(--space-md) var(--space-lg);
    }

    .cta__buttons {
      flex-direction: column;
      width: 100%;
      max-width: 360px;
    }

    .cta__btn-primary,
    .cta__btn-outline {
      width: 100%;
      justify-content: center;
      font-size: var(--fs-body);
      padding: var(--space-md) var(--space-xl);
    }

    .cta__proof {
      flex-direction: column;
      gap: var(--space-sm);
    }
  }
</style>
