---
const testimonials = [
  {
    name: "Sarah M.",
    role: "Home Cook",
    avatar: "👩‍🍳",
    avatarBg: "#FFE0E6",
    quote:
      "Laook completely changed how I think about cooking. I just snap a photo and get amazing recipes I never would have thought of!",
  },
  {
    name: "James K.",
    role: "College Student",
    avatar: "👨‍🎓",
    avatarBg: "#DBEAFE",
    quote:
      "As a student with a limited budget, Laook helps me make the most of whatever ingredients I have. It's like having a chef in my pocket.",
  },
  {
    name: "Priya R.",
    role: "Food Blogger",
    avatar: "👩‍💻",
    avatarBg: "#D1FAE5",
    quote:
      "The AI recognition is incredibly accurate. I've been recommending Laook to all my followers. It's a game-changer for meal planning.",
  },
];

const stars = Array.from({ length: 5 });
---

<section id="testimonials" class="section">
  <div class="container">
    <div class="testimonials-header animate-fade-in-up">
      <span class="badge">💬 What Users Say</span>
      <h2 class="testimonials-heading">Loved by Home Cooks Everywhere</h2>
      <p class="testimonials-subtext">
        See what our community has to say about Laook.
      </p>
    </div>

    <div class="testimonials-grid">
      {testimonials.map((t, index) => (
        <article
          class={`testimonial-card animate-fade-in-up animate-delay-${index + 1}`}
        >
          {/* Decorative quote mark */}
          <span class="testimonial-card__quote-mark" aria-hidden="true">
            "
          </span>

          {/* Star rating */}
          <div class="testimonial-card__stars">
            {stars.map(() => (
              <svg
                class="star-icon"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="var(--color-warning)"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
              </svg>
            ))}
          </div>

          {/* Quote */}
          <blockquote class="testimonial-card__text">
            <p>{t.quote}</p>
          </blockquote>

          {/* Author */}
          <div class="testimonial-card__author">
            <div
              class="testimonial-card__avatar"
              style={`background: ${t.avatarBg};`}
            >
              <span>{t.avatar}</span>
            </div>
            <div class="testimonial-card__info">
              <strong class="testimonial-card__name">{t.name}</strong>
              <span class="testimonial-card__role">{t.role}</span>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  /* ── Section Header ── */
  .testimonials-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .testimonials-heading {
    font-size: var(--fs-h1);
    font-family: var(--font-display);
    color: var(--color-ink);
    margin-top: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .testimonials-subtext {
    font-size: var(--fs-body-lg);
    color: var(--color-ink-secondary);
    line-height: var(--lh-relaxed);
    max-width: 480px;
    margin: 0 auto;
  }

  /* ── Grid ── */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    align-items: stretch;
  }

  /* ── Card ── */
  .testimonial-card {
    position: relative;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-light);
    border-radius: var(--radius-lg);
    padding: var(--space-xl) var(--space-lg) var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    overflow: hidden;
    cursor: default;
    transition:
      transform var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      border-color var(--duration-normal) var(--ease-out);
  }

  .testimonial-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-primary-lighter);
  }

  /* ── Decorative Quote Mark ── */
  .testimonial-card__quote-mark {
    position: absolute;
    top: -8px;
    right: var(--space-lg);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 6rem;
    line-height: 1;
    color: var(--color-primary);
    opacity: 0.07;
    pointer-events: none;
    user-select: none;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .testimonial-card:hover .testimonial-card__quote-mark {
    opacity: 0.14;
  }

  /* ── Stars ── */
  .testimonial-card__stars {
    display: flex;
    gap: 2px;
  }

  .star-icon {
    filter: drop-shadow(0 1px 2px rgba(224, 121, 18, 0.3));
  }

  /* ── Quote Text ── */
  .testimonial-card__text {
    flex: 1;
  }

  .testimonial-card__text p {
    font-size: var(--fs-body);
    font-style: italic;
    color: var(--color-ink-secondary);
    line-height: var(--lh-relaxed);
    position: relative;
  }

  /* ── Author Row ── */
  .testimonial-card__author {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border-light);
  }

  .testimonial-card__avatar {
    width: 48px;
    height: 48px;
    border-radius: var(--radius-pill);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .testimonial-card:hover .testimonial-card__avatar {
    transform: scale(1.1);
  }

  .testimonial-card__info {
    display: flex;
    flex-direction: column;
  }

  .testimonial-card__name {
    font-family: var(--font-display);
    font-size: var(--fs-body);
    font-weight: 700;
    color: var(--color-ink);
    line-height: var(--lh-tight);
  }

  .testimonial-card__role {
    font-size: var(--fs-caption);
    color: var(--color-ink-tertiary);
    font-weight: 500;
    margin-top: 2px;
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .testimonials-grid {
      grid-template-columns: 1fr 1fr;
    }

    /* Center the third card on its own row */
    .testimonial-card:last-child {
      grid-column: 1 / -1;
      max-width: 480px;
      justify-self: center;
    }
  }

  @media (max-width: 600px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .testimonial-card:last-child {
      max-width: 100%;
    }

    .testimonial-card {
      padding: var(--space-lg) var(--space-md) var(--space-md);
    }
  }
</style>
