    <ul class="navbar__links hide-mobile" id="nav-links">
      <li><a href="#features">Features</a></li>
      <li><a href="#how-it-works">How It Works</a></li>
      <li><a href="#tech">Technology</a></li>
      <li><a href="#testimonials">Testimonials</a></li>
    </ul>

    <div class="navbar__actions">
      <a href="https://github.com/LaookProj" target="_blank" rel="noopener" class="navbar__github hide-mobile" id="nav-github">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href="#cta" class="btn btn--primary navbar__cta" id="nav-cta">Get Started</a>
    </div>

    <button class="navbar__hamburger hide-desktop" id="nav-hamburger" aria-label="Toggle menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="navbar__mobile-menu" id="mobile-menu">
    <ul>
      <li><a href="#features">Features</a></li>
      <li><a href="#how-it-works">How It Works</a></li>
      <li><a href="#tech">Technology</a></li>
      <li><a href="#testimonials">Testimonials</a></li>
      <li><a href="#cta" class="btn btn--primary" style="width:100%;margin-top:8px;">Get Started</a></li>
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--color-border-light);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .navbar__logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-ink);
  }

  .navbar__logo-icon {
    font-size: 1.75rem;
  }

  .navbar__logo-text {
    background: var(--gradient-cta);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .navbar__links {
    display: flex;
    gap: var(--space-xl);
  }

  .navbar__links a {
    font-size: var(--fs-caption);
    font-weight: 500;
    color: var(--color-ink-secondary);
    transition: color var(--duration-fast) var(--ease-out);
    position: relative;
  }

  .navbar__links a::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-primary);
    border-radius: 1px;
    transition: width var(--duration-normal) var(--ease-out);
  }

  .navbar__links a:hover {
    color: var(--color-ink);
  }

  .navbar__links a:hover::after {
    width: 100%;
  }

  .navbar__actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .navbar__github {
    display: flex;
    align-items: center;
    padding: var(--space-sm);
    border-radius: var(--radius-sm);
    color: var(--color-ink-secondary);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .navbar__github:hover {
    color: var(--color-ink);
    background: var(--color-surface-secondary);
  }

  .navbar__cta {
    padding: var(--space-sm) var(--space-lg);
    font-size: var(--fs-caption);
  }

  .navbar__hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: var(--space-sm);
  }

  .navbar__hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-ink);
    border-radius: 1px;
    transition: all var(--duration-normal) var(--ease-out);
  }

  .navbar__mobile-menu {
    display: none;
    padding: var(--space-md) var(--space-lg) var(--space-lg);
    border-top: 1px solid var(--color-border-light);
  }

  .navbar__mobile-menu.active {
    display: block;
  }

  .navbar__mobile-menu ul {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .navbar__mobile-menu a {
    display: block;
    padding: var(--space-sm) 0;
    font-size: var(--fs-body);
    font-weight: 500;
    color: var(--color-ink-secondary);
  }

  .navbar__mobile-menu a:hover {
    color: var(--color-ink);
  }
</style>

<script>
  const hamburger = document.getElementById('nav-hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('active');
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.remove('active');
    });
  });

  // Navbar scroll effect
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });
</script>
